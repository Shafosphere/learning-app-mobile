{
  "expo": {
    "name": "Memicard",
    "slug": "memicard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icons/generated/ios/AppIcon~ios-marketing.png",
    "scheme": "memicard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/app/icons/generated/ios/AppIcon~ios-marketing.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/icons/generated/android/res/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./assets/app/icons/generated/android/res/mipmap-xxxhdpi/ic_launcher_background.png"
      },
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.memicard.app"
    },
    "splash": {
      "image": "./assets/app/splash/splash-icon-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f4f6"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/app/icons/legacy/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app/splash/splash-icon-v2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f2f4f6",
          "dark": {
            "backgroundColor": "#001534",
            "image": "./assets/app/splash/splash-icon-v2.png"
          }
        }
      ],
      "expo-sqlite",
      "expo-asset",
      "expo-audio",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/app/icons/notification-icon.png",
          "color": "#001534"
        }
      ],
      "expo-mail-composer"
    ],
    "extra": {
      "googleDriveBackup": {
        "webClientId": "493135568689-p2rjn4hfgmq9gfe0qa0krt5j0pt3smud.apps.googleusercontent.com"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
